{
  "name": "web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "CLOUDFLARE_ENV=local vite dev --port 3000",
    "build": "vite build",
    "build:preview": "rimraf dist && CLOUDFLARE_ENV=preview vite build --mode preview",
    "build:analyze": "ANALYZE=true vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "typegen:cf": "wrangler types",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "oxlint && eslint",
    "format": "prettier",
    "check": "prettier --write . && oxlint && eslint --fix",
    "db:generate": "drizzle-kit generate --config ./src/db/config/drizzle-local.config.ts",
    "db:migrate:local": "drizzle-kit migrate --config ./src/db/config/drizzle-local.config.ts",
    "db:migrate:preview": "drizzle-kit migrate --config ./src/db/config/drizzle-preview.config.ts",
    "db:migrate:dev": "drizzle-kit migrate --config ./src/db/config/drizzle-dev.config.ts",
    "db:migrate:stg": "drizzle-kit migrate --config ./src/db/config/drizzle-stg.config.ts",
    "db:migrate:prod": "drizzle-kit migrate --config ./src/db/config/drizzle-prod.config.ts",
    "db:view:local": "drizzle-kit studio --config ./src/db/config/drizzle-local.config.ts",
    "db:view:preview": "drizzle-kit studio --config ./src/db/config/drizzle-preview.config.ts",
    "db:view:dev": "drizzle-kit studio --config ./src/db/config/drizzle-dev.config.ts",
    "db:view:stg": "drizzle-kit studio --config ./src/db/config/drizzle-stg.config.ts",
    "db:view:prod": "drizzle-kit studio --config ./src/db/config/drizzle-prod.config.ts",
    "db:drop:local": "wrangler d1 execute tanstack-test-local --env local --local --file='./src/db/seed/drop-all-table.sql' --config=./wrangler.jsonc",
    "db:drop:preview": "wrangler d1 execute tanstack-test-preview --env preview --local --file='./src/db/seed/drop-all-table.sql' --config=./wrangler.jsonc",
    "db:drop:dev": "wrangler d1 execute tanstack-test-develop --env develop --remote --file='./src/db/seed/drop-all-table.sql' --config=./wrangler.jsonc",
    "db:drop:stg": "wrangler d1 execute tanstack-test-staging --env staging --remote --file='./src/db/seed/drop-all-table.sql' --config=./wrangler.jsonc",
    "db:drop:prod": "echo \"🔥 Be careful 🔥\\nYou can delete all tables by executing:\\n> wrangler d1 execute tanstack-test --remote --file='./src/db/seed/drop-all-table.sql' --config=./wrangler.jsonc\""
  },
  "dependencies": {
    "@repo/math": "workspace:*",
    "@cloudflare/vite-plugin": "^1.38.0",
    "@hono/zod-validator": "^0.8.0",
    "@hookform/resolvers": "^5.4.0",
    "@libsql/client": "^0.15.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-devtools": "^0.10.5",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-query-devtools": "^5.100.14",
    "@tanstack/react-router": "^1.170.8",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-router-ssr-query": "^1.167.0",
    "@tanstack/react-start": "^1.168.12",
    "@tanstack/router-plugin": "^1.168.11",
    "better-auth": "^1.6.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.22",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-error-boundary": "^6.1.0",
    "react-hook-form": "^7.76.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "vite-tsconfig-paths": "^6.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tanstack/devtools-vite": "^0.7.0",
    "@tanstack/eslint-config": "^0.4.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.4",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.0.17",
    "@vitest/ui": "^4.1.7",
    "drizzle-kit": "^0.31.10",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "rimraf": "^6.1.2",
    "rollup-plugin-visualizer": "^6.0.5",
    "typescript": "^5.9.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "web-vitals": "^5.2.0",
    "wrangler": "^4.92.0"
  },
  "engines": {
    "node": "24.11.x"
  }
}
