{
  "env": {
    "MAX_THINKING_TOKENS": "10000",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "50",
    "CLAUDE_CODE_SUBAGENT_MODEL": "haiku"
  },
  "permissions": {
    "allow": [
      "Bash(pnpm dev)",
      "Bash(pnpm dev *)",
      "Bash(pnpm start)",
      "Bash(pnpm start *)",
      "Bash(pnpm build)",
      "Bash(pnpm build *)",
      "Bash(pnpm run build)",
      "Bash(pnpm run build *)",
      "Bash(pnpm typecheck)",
      "Bash(pnpm typecheck *)",
      "Bash(pnpm test)",
      "Bash(pnpm test *)",
      "Bash(pnpm check)",
      "Bash(pnpm check *)",
      "Bash(pnpm lint)",
      "Bash(pnpm lint *)",
      "mcp__serena"
    ],
    "deny": []
  },
    "enableAllProjectMcpServers": true,
    "enabledMcpjsonServers": [
        "serena"
    ],
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Write|Edit|MultiEdit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "jq -r '.tool_input.file_path // empty' | grep -E '\\.(ts|tsx|js|jsx)$' | xargs -I {} sh -c 'f={}; case $f in /*) ;; *) f=$(pwd)/$f ;; esac; pnpm --filter web exec eslint --fix $f 2>/dev/null || true'"
                    },
                    {
                        "type": "command",
                        "command": "jq -r '.tool_input.file_path // empty' | grep -E '\\.(ts|tsx|js|jsx|json|md)$' | xargs -I {} pnpm exec prettier --write {} 2>/dev/null || true"
                    },
                    {
                        "type": "command",
                        "command": "jq -r '.tool_input.file_path // empty' | grep -E '\\.md$' | xargs -I {} pnpm exec textlint --fix {} 2>/dev/null || true"
                    }
                ]
            }
        ],
        "Stop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/full-check.js",
                        "timeout": 120
                    }
                ]
            }
        ]
    }
}